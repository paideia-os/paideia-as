// Phase 4 m11-004: hashmap_remove_returns_value
// Fixture: HashMap::remove() returns the value for a present key.

use paideia.raw_mem;

fn test_hashmap_remove_returns_value() -> u64 {
  let hm = hashmap_new();
  let hm = hashmap_insert(hm, 42, 100);
  let hm = hashmap_remove(hm, 42);
  hashmap_len(hm)
}
