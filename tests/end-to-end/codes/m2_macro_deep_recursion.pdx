   */
  #[reflect]
  macro deep_recursion =
    fn(t) => {
      let a1 = 1
      let a2 = 2
      let a3 = 3
      let a4 = 4
      let a5 = 5
      let a6 = 6
      let a7 = 7
      let a8 = 8
      let a9 = 9
      let a10 = 10
      /* ... many more let bindings would follow ...
         This is a simplified example; a real deep recursion test
         would have enough nested lets to exceed depth limit. */
      a10
    }

  let w = 0
}
