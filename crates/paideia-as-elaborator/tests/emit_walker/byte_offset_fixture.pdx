/// Phase 7 m1-003: Regression fixture for byte-position collapse
/// Tests interleaved call instructions that triggered off-by-one reloc offset errors
/// when encoder read buf.bytes.len() after encoding rather than before.
///
/// The bug manifested with 6 calls in kernel_main: calls at indices 1, 3, 5 had
/// reloc offsets off by +1 because of interleaved instruction emission.

fn four_unsafe_blocks() {
  unsafe {
    // Block 1: simple call
    call bootstrap_stage1();
  }

  unsafe {
    // Block 2: call + another instruction
    call bootstrap_stage2();
    // This padding instruction shifts subsequent blocks
  }

  unsafe {
    // Block 3: call (this one was oft-by-one pre-fix)
    call bootstrap_stage3();
  }

  unsafe {
    // Block 4: call + cleanup
    call bootstrap_stage4();
  }
}

// Extern references to functions we'll call
extern "C" {
  fn bootstrap_stage1();
  fn bootstrap_stage2();
  fn bootstrap_stage3();
  fn bootstrap_stage4();
}
