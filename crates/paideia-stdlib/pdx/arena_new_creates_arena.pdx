// Phase 4 m10-003: Fixture — arena_new_creates_arena
//
// Verify that arena_new initializes an Arena with a head region.
// Phase-4-m10-003 minimum: parse-only; full elaborator-side execution
// gates on m1 walker work.

struct Region {
  base: *u8,
  offset: u64,
  capacity: u64,
  next: *Region,
}

struct Arena {
  head: *Region,
}
