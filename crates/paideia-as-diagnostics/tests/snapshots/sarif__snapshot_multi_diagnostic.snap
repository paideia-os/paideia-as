              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Phase 6 m5-001: The uninit keyword can only be used as the right-hand side of a mutable let binding. It cannot appear as a general expression in function calls, return statements, or other contexts. Use it only in patterns like `let mut x: Type = uninit;`."
              },
              "helpUri": "https://paideia-os.org/diagnostics/P0221",
              "id": "P0221",
              "name": "uninit not valid in this position",
              "shortDescription": {
