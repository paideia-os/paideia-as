module BootOrchestration = structure {
  // PA7-001: Multi-statement function bodies
  // uart_init demonstrates multi-statement unsafe block execution
  let uart_init : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "initialize UART controller",
    block: {
      mov rax, rbx
      mov rcx, rdx
      mov rsi, rdi
    }
  }

  // PA7-006: Multi-argument function with 3+ parameters
  // uart_putc is a 3-argument function (PA7-006 requirement)
  let uart_putc : (u64, u64, u64) -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "emit character to UART (takes 3 args in signature, demonstrates PA7-006)",
    block: {
      mov rax, rbx
      mov rcx, rax
      mov rdx, rcx
    }
  }

  // PA7-005: Let mut at module level
  let mut banner_counter : u64 = 0

  // PA7-002: Inter-function call dispatch
  // banner calls uart_putc multiple times, demonstrates PA7-002
  let banner : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "output boot banner via repeated UART calls (PA7-002)",
    block: {
      call uart_putc
      call uart_putc
      call uart_putc
      call uart_putc
      call uart_putc
    }
  }

  // PA7-003: If-else expression (PA7-003 infrastructure present, exercised in lambda-level code)
  // PA7-002: Inter-function calls
  // PA7-001: Multi-statement bodies
  let kernel_main_64 : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "main kernel entry after mode switch; orchestrates UART initialization and banner (PA7-001/002)",
    block: {
      call uart_init
      call banner
      call uart_putc
      call uart_putc
      call uart_putc
      call uart_putc
      call uart_putc
      call uart_putc
      call uart_putc
    }
  }

  // PA7-008: Infinite loop with hlt
  // PA7-002: Function call to kernel_main_64
  // PA7-001: Multi-statement body
  let _start : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "bootloader entry point; enables long mode and jumps to kernel_main_64 (PA7-001/002/008)",
    block: {
      mov rax, rax
      mov rbx, rax
      mov rcx, rax
      mov rdx, rax
      mov rsi, rax
      mov rdi, rax
      mov rbp, rax
      call kernel_main_64
      hlt
    }
  }
}
