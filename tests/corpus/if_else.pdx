// Phase 7 m1-001: If-else expression lowering test fixtures.
// Tests basic and nested if-else control flow.

// Test 1: Simple if without else
// Returns unit type; tests if-expr with no else branch
fn simple_if(x: u64) {
    if x {
        // Then-block (empty for now)
    }
}

// Test 2: If-else with both branches
// Both branches return u64; type-checked by elaborator
fn if_else_u64(x: u64) -> u64 {
    if x == 0 {
        // Then: x is zero
        0
    } else {
        // Else: x is nonzero
        1
    }
}

// Test 3: Nested if-else
// Outer if-else contains inner if-else
fn nested_if(x: u64, y: u64) -> u64 {
    if x == 0 {
        if y == 0 {
            0
        } else {
            1
        }
    } else {
        if y == 0 {
            2
        } else {
            3
        }
    }
}
