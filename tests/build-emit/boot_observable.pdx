module BootObservable = structure {
  // PA10: End-to-end "boot-to-banner-and-cap-smoke" closure fixture
  //
  // This fixture exercises PA10-001..005 composed end-to-end:
  // - PA10-001: Multiboot2/PVH ELF note (automatic via build pipeline)
  // - PA10-002: String literals support at IR level (PA10-002 infrastructure)
  // - PA10-003: Bitwise arithmetic encoders (AND/OR/XOR machine instructions)
  // - PA10-004: Narrow-form Mov instructions (r8-imm, r16-imm)
  // - PA10-005: Nested let-of-Var in deep block bodies
  // - PA10-006l: in_al/out_al I/O port mnemonics
  //
  // The fixture outputs "PA10" banner via UART using narrow Mov and nested lets.

  // PA10-004: Narrow-form Mov for byte operands (mov al, imm8)
  // Combined with PA10-005: nested let-of-Var pattern
  let kernel_main : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "output PA10 banner via narrow mov and nested lets (PA10-004/005)",
    block: {
      // PA10-005: outer let binding
      let uart : u64 = 0x3F8

      // PA10-004: narrow mov al, imm8 for 'P' (0x50)
      mov al, 0x50
      mov dx, uart
      out_al al

      // PA10-005: inner let re-binding
      let p : u64 = uart
      mov al, 0x41
      mov dx, p
      out_al al

      // Another nested let
      let p2 : u64 = uart
      mov al, 0x31
      mov dx, p2
      out_al al

      // Yet another
      let p3 : u64 = uart
      mov al, 0x30
      mov dx, p3
      out_al al
    }
  }

  // PA10-003: Bitwise arithmetic (AND/OR/XOR) encoders demonstration
  // This tests that the encoder implementations work with reg-reg forms
  let bitwise_demo : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "demonstrate bitwise AND/OR/XOR encoders (PA10-003)",
    block: {
      // AND reg, reg
      mov rax, rbx
      and rax, rbx

      // OR reg, reg
      mov rcx, rdx
      or rcx, rdx

      // XOR reg, reg
      mov rsi, rdi
      xor rsi, rdi
    }
  }

  // PA10-001: Entry point with PVH note (automatic via build pipeline)
  let _start : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "bootloader entry point with PVH-Note ELF metadata (PA10-001)",
    block: {
      call kernel_main
      hlt
    }
  }
}
