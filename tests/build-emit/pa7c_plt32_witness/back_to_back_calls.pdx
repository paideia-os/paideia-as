// Back-to-back calls to multiple internal functions (3 calls)
module BackToBackCalls = structure {
  let tgt_a : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "target a",
    block: { ret }
  }

  let tgt_b : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "target b",
    block: { ret }
  }

  let tgt_c : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "target c",
    block: { ret }
  }

  let caller : () -> () !{} @{} = fn(_: ()) -> unsafe {
    effects: {},
    capabilities: {},
    justification: "calling functions sequentially",
    block: { call tgt_a; call tgt_b; call tgt_c; ret }
  }
}
