// Phase 4 m13-002: minimal .pdx lexer expressed in .pdx
//
// Recognises a tiny subset of .pdx syntax:
// - Idents: [a-zA-Z_][a-zA-Z_0-9]*
// - Integer literals: 0-9+
// - Whitespace: skip
// - Operators: + - * / = ( ) { } , ;
//
// Output: token list. Not a port of paideia-as-lexer; parallel impl
// proving the surface is sufficient to express a real lexer.

enum Token {
  Ident,         // followed by source span
  IntLit,        // followed by source span
  Plus,
  Minus,
  Star,
  Slash,
  Assign,
  LParen,
  RParen,
  LBrace,
  RBrace,
  Comma,
  Semicolon,
  EndOfInput,
}

struct Lexer {
  pos: u64,
  // input: &str  // Phase-4-m13-002 honest: byte slicing gates on m11
                  // string-slice methods; today the input is implicit
                  // via the bootstrap-fixture's caller setup.
}

// Phase-4-m13-002 honest scope: the mini-lexer's body uses the
// stdlib operations available today (Option/Result/Vec/match).
// Full execution gates on the Phase 5 runtime evaluator; today
// the fixture demonstrates the SURFACE is expressive enough.

trait LexerOps {
  fn next() -> Option(Token);
}

impl LexerOps for Lexer {
  let next = fn(x: ()) -> Option(Token) = None
}

// Demonstration: the mini-lexer's API surface is
//   let lexer = Lexer { pos: 0 }
//   loop {
//     match lexer.next() {
//       Some(tok) => process(tok),
//       None      => break
//     }
//   }
