// Three levels of nested handlers
module ThreeDeep = structure {
  effect A {
    op a : (unit) -> unit
  }

  effect B {
    op b : (unit) -> unit
  }

  effect C {
    op c : (unit) -> unit
  }

  let triple : (unit) -> unit !{} =
    fn (_ : unit) ->
      with a_handler handle A {
        with b_handler handle B {
          with c_handler handle C {
            0
          }
        }
      }
}
