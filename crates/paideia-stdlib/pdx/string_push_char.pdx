// Phase 4 m11-003: Fixture — string_push_char
//
// Verify that push appends a single byte to a linear String.
// Phase-4-m11-003 minimum: parse-only; full elaborator-side execution
// gates on m1 walker work.

struct String {
  data: *u8,
  len: u64,
  cap: u64,
}

trait StringPush {
  fn string_push(s: linear String, ch: u8) -> String;
}
