// Fixture: iterator_fold
// Tests that Iterator::fold(self, init, f) -> u64 parses cleanly.

record RangeIter {
  start: u64,
  end: u64,
}

trait Iterator {
  type Item;
  fn next(self: linear Self) -> Option !{} @{};
  fn fold(self: linear Self, init: u64, f: (u64, u64) -> u64) -> u64 !{} @{} { init }
}

impl Iterator for RangeIter {
  type Item = u64;
  fn next(self: linear Self) -> Option {
    None
  }
}
